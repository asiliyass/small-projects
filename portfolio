<!DOCTYPE html> 
<html lang="en"> 
<head> 
    <meta charset="UTF-8"> 
    <title>untitled!</title> 
 
    <style> 
        body { 
            margin: 0; 
            background: #8B0000; 
            color: white; 
            font-family: Arial, sans-serif; 
        } 
 
        /* Navbar (Menu with border + Lucida Console) */ 
        .navbar { 
            display: flex; 
            background: #b30000; 
            padding: 10px; 
            border-bottom: 2px solid white; 
        } 
 
        .navbar button { 
            background: none; 
            border: 2px solid white; 
            color: white; 
            padding: 10px 18px; 
            margin-right: 10px; 
            cursor: pointer; 
            font-size: 16px; 
            font-family: "Lucida Console", monospace; 
            border-radius: 20px; /* sharp oval */ 
            transition: 0.3s; 
             box-shadow: 0 6px 12px rgba(0,0,0,0.6); 
        } 
 
        .navbar button:hover { 
            background: white; 
            color: #8B0000; 
            border: 2px solid white; 
        } 
 
        /* Sections */ 
        .tab-content { 
            display: none; 
            padding: 40px; 
        } 
 
        .active { 
            display: block; 
        } 
 
        /* Hero Section */ 
        .hero { 
            text-align: center; 
            margin-top: 100px; 
        } 
 
        .hero h1 { 
            font-size: 48px; 
        } 
 
        .hero p { 
            color: #ffe6e6; 
        } 
 
        /* Button with border + hover */ 
        .hero button { 
            margin-top: 25px; 
            padding: 12px 30px; 
            font-size: 18px; 
            border: 2px solid white; 
            background: transparent; 
            color: white; 
            cursor: pointer; 
            border-radius: 40px; /* oval but sharper */ 
            font-weight: bold; 
            font-family: monospace; 
             box-shadow: 0 6px 12px rgba(0,0,0,0.6); 
            transition: 0.3s; 
        } 
 
        .hero button:hover { 
            background: white; 
            color: #8B0000; 
            border: 2px solid white; 
             box-shadow: 0 6px 12px rgba(0,0,0,0.6); 
        } 
 
    </style> 
</head> 
 
<body> 
 
    <!-- Menu --> 
    <div class="navbar"> 
        <button onclick="openTab('home')">Home</button> 
        <button onclick="openTab('about')">About</button> 
        <button onclick="openTab('contact')">Contact</button> 
    </div> 
 
    <!-- Home --> 
    <div id="home" class="tab-content active"> 
        <div class="hero"> 
            <h1 style="text-shadow: 4px 4px 0px #5a0000, 0 0 30px 
rgba(139,0,0,0.8);">Welcome to My Website</h1> 
            <h2 style="font-family: 'Courier New', monospace; letter-spacing: 
6px; text-shadow: 4px 4px 0px #5a0000, 0 0 30px rgba(139,0,0,0.8); image
rendering: pixelated; font-size: 20px;">Occasional Developer</h2> 
            <button 
onclick="window.location.href='https://www.instagram.com/reel/DWL1vlMiDPm/?utm_so
urce=ig_web_copy_link&igsh=MzRlODBiNWFlZA=='">Go to About Page</button> 
 
        </div> 
    </div> 
 
    <!-- About --> 
    <div id="about" class="tab-content"> 
        <center><h1 style="font-family: 'Courier New', monospace; font-size: 
52px; letter-spacing: 6px; text-shadow: 4px 4px 0px #5a0000, 0 0 30px 
rgba(139,0,0,0.8);">About...</h1></center> 
       <center><p style="margin-top: 120px; font-size: 28px; font-family: 'Lucida 
Console', monospace; letter-spacing: 4px; color: #ffe6e6; text-shadow: 4px 4px 
0px #5a0000, 0 0 30px rgba(139,0,0,0.8);">Code, Coffee, Repeat</p></center> 
         
    </div> 
 
    <!-- Contact --> 
    <div id="contact" class="tab-content"> 
        <h2 style="font-family: 'Lucida Console', monospace; letter-spacing: 6px; 
text-shadow: 4px 4px 0px #5a0000, 0 0 30px rgba(139,0,0,0.8); text-align: 
center;">Contact</h2> 
         
 
<center><button 
onclick="window.location.href='https://mail.google.com/mail/u/0/#inbox'"  
    style="margin-top: 20px; padding: 12px 30px; font-size: 18px; border: 2px 
solid white; background: transparent; color: white; cursor: pointer; border
radius: 40px; font-weight: bold; font-family: monospace; box-shadow: 0 6px 12px 
rgba(0,0,0,0.6); transition: 0.3s;" 
    onmouseover="this.style.background='white'; this.style.color='#8B0000';" 
    onmouseout="this.style.background='transparent'; this.style.color='white';"> 
    Mail Me 
</button></center>         
    </div> 
 
     
 
    <!-- JS --> 
    <script> 
        function openTab(tabName) { 
            let tabs = document.getElementsByClassName("tab-content"); 
            for (let i = 0; i < tabs.length; i++) { 
                tabs[i].classList.remove("active"); 
            } 
            document.getElementById(tabName).classList.add("active"); 
        } 
    </script> 
 
</body> 
</html> 
 
 
